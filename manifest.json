{
  "manifest_version": 3,
  "name": "GV AMD Detector",
  "version": "1.1.0",
  "description": "Google Voice answering machine detection with local tab-audio metrics and optional backend transcription. Does not record audio.",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "tabCapture",
    "offscreen"
  ],
  "host_permissions": [
    "https://voice.google.com/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "GV AMD Detector",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://voice.google.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "overlay.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "overlay.css"
      ],
      "matches": [
        "https://voice.google.com/*"
      ]
    }
  ]
}
